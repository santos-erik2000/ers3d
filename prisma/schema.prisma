// ERS 3D — Gestão de Soluções e Fabricações
// Sprint 0/1 scope: fundação (usuários, permissões por ação, auditoria).
// Demais módulos (customers, crm, quotes, jobs, filaments, inventory, quality,
// deliveries, finance, ...) entram em schemas incrementais nos próximos sprints,
// conforme o roadmap da Etapa 5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles UserRole[]
  auditLogs AuditLog[]
  // Clientes onde este usuário é o responsável comercial (Sprint 2 — customers.ownerId).
  customers Customer[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  // Ação nomeada, ex.: "finance.read", "inventory.adjust", "crm.stage.revert"
  // A checagem de acesso é sempre feita contra este slug, nunca contra o nome do perfil.
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Trilha de auditoria transversal (Etapa 1, seção 11 / Etapa 3, seção 04).
// Escrita sempre via src/lib/audit.ts — nunca manualmente em cada service.
model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  reason     String?
  userId     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Clientes (Etapa 5, Sprint 2 — épico E2, histórias CUST-1..CUST-4).
// ---------------------------------------------------------------------------

enum CustomerType {
  PF
  PJ
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

// "Empresa" do cliente é uma tag leve para agrupar/filtrar em relatórios e
// dashboard (decisão registrada em planejamento/01-visao-arquitetura.html,
// callout "Decidido · Campo 'empresa' do cliente"): não tem contatos,
// endereços nem oportunidades próprios — só nome e segmento opcional.
model Company {
  id        String   @id @default(uuid())
  name      String
  segment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers Customer[]

  @@map("companies")
}

// Cadastro de clientes PF/PJ (CUST-1). Documento (CPF/CNPJ) e telefones são
// normalizados (somente dígitos) por src/modules/customers/services/customers.ts
// antes de gravar, para viabilizar a checagem de duplicidade (CUST-2). Não há
// unique constraint de banco sobre email/documento/telefone de propósito: a
// jornada "Detecção de duplicidade de cliente" (Etapa 2, seção 03) exige que o
// alerta seja apresentado ao usuário, que decide confirmar o cadastro mesmo
// assim — nunca um bloqueio silencioso no banco.
model Customer {
  id            String         @id @default(uuid())
  name          String
  type          CustomerType
  document      String?
  email         String?
  phone         String?
  whatsapp      String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  origin        String?
  segment       String?
  notes         String?
  tags          String[]       @default([])
  status        CustomerStatus @default(ACTIVE)
  lastContactAt DateTime?
  nextContactAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([document])
  @@index([phone])
  @@index([whatsapp])
  @@index([ownerId])
  @@index([companyId])
  @@map("customers")
}
