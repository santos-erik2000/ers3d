// ERS 3D — Gestão de Soluções e Fabricações
// Sprint 0/1 scope: fundação (usuários, permissões por ação, auditoria).
// Demais módulos (customers, crm, quotes, jobs, filaments, inventory, quality,
// deliveries, finance, ...) entram em schemas incrementais nos próximos sprints,
// conforme o roadmap da Etapa 5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles             UserRole[]
  auditLogs             AuditLog[]
  // Clientes onde este usuário é o responsável comercial (Sprint 2 — customers.ownerId).
  customers             Customer[]
  // Oportunidades onde este usuário é o responsável comercial (Sprint 3 — opportunities.ownerId).
  ownedOpportunities    Opportunity[]             @relation("OpportunityOwner")
  // Movimentações de etapa do Kanban feitas por este usuário (Sprint 3).
  opportunityStageMoves OpportunityStageHistory[] @relation("OpportunityStageMover")
  // Movimentações de estoque de filamento feitas por este usuário (Sprint 4).
  filamentMovements     FilamentMovement[]        @relation("FilamentMovementActor")
  // Projetos onde este usuário é o responsável técnico (Sprint 4 — projects.responsibleId).
  responsibleProjects   Project[]                 @relation("ProjectResponsible")
  // Ciclos mensais fechados por este usuário (Sprint 5 — crm_cycles.closed_by).
  closedCycles          CrmCycle[]                @relation("CrmCycleClosedBy")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  // Ação nomeada, ex.: "finance.read", "inventory.adjust", "crm.stage.revert"
  // A checagem de acesso é sempre feita contra este slug, nunca contra o nome do perfil.
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Trilha de auditoria transversal (Etapa 1, seção 11 / Etapa 3, seção 04).
// Escrita sempre via src/lib/audit.ts — nunca manualmente em cada service.
model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  reason     String?
  userId     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Clientes (Etapa 5, Sprint 2 — épico E2, histórias CUST-1..CUST-4).
// ---------------------------------------------------------------------------

enum CustomerType {
  PF
  PJ
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

// "Empresa" do cliente é uma tag leve para agrupar/filtrar em relatórios e
// dashboard (decisão registrada em planejamento/01-visao-arquitetura.html,
// callout "Decidido · Campo 'empresa' do cliente"): não tem contatos,
// endereços nem oportunidades próprios — só nome e segmento opcional.
model Company {
  id        String   @id @default(uuid())
  name      String
  segment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers Customer[]

  @@map("companies")
}

// Cadastro de clientes PF/PJ (CUST-1). Documento (CPF/CNPJ) e telefones são
// normalizados (somente dígitos) por src/modules/customers/services/customers.ts
// antes de gravar, para viabilizar a checagem de duplicidade (CUST-2). Não há
// unique constraint de banco sobre email/documento/telefone de propósito: a
// jornada "Detecção de duplicidade de cliente" (Etapa 2, seção 03) exige que o
// alerta seja apresentado ao usuário, que decide confirmar o cadastro mesmo
// assim — nunca um bloqueio silencioso no banco.
model Customer {
  id            String         @id @default(uuid())
  name          String
  type          CustomerType
  document      String?
  email         String?
  phone         String?
  whatsapp      String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  origin        String?
  segment       String?
  notes         String?
  tags          String[]       @default([])
  status        CustomerStatus @default(ACTIVE)
  lastContactAt DateTime?
  nextContactAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  opportunities Opportunity[]
  // Projetos da calculadora vinculados a este cliente (Sprint 4, opcional).
  projects      Project[]

  @@index([email])
  @@index([document])
  @@index([phone])
  @@index([whatsapp])
  @@index([ownerId])
  @@index([companyId])
  @@map("customers")
}

// ---------------------------------------------------------------------------
// Kanban CRM (Etapa 5, Sprint 3 — épico E3, histórias CRM-1..CRM-5) + Ciclo
// mensal e Orçamento (Sprint 5 — épico E4 CALC-4/CALC-5, épico E3 CRM-5).
// Fluxo e pré-condições de transição: planejamento/01-visao-arquitetura.html
// seções 08/09. Quem pode mover cada transição por perfil:
// planejamento/02-personas-jornadas-historias.html seção 06.
//
// A partir do Sprint 5, `quotes`/`quote_versions` (orçamento formal,
// versionado — nunca sobrescrito, ver `QuoteVersion` abaixo) e `crm_cycles`
// (ciclo mensal, `Opportunity.cycleId`/`carriedFromCycleId`) existem de
// verdade — a pré-condição "orçamento aprovado" de Negociação → Desenvolvimento
// passou a ser checada de verdade em `validateTransition`
// (src/modules/crm/services/opportunities.ts). As demais pré-condições que
// ainda dependem de módulos futuros (produção concluída, qualidade aprovada,
// entrega registrada) continuam marcadas como TODO — nunca uma checagem
// falsa, nunca um bloqueio inventado.
// ---------------------------------------------------------------------------

// Ciclo mensal do Kanban (CRM-5). Fechamento nunca é destrutivo: cards ainda
// abertos (stage != CONCLUIDO) no ciclo sendo fechado exigem uma decisão
// explícita por card (ver `Opportunity.carriedFromCycleId` e
// src/modules/crm/services/cycles.ts, função `closeCycle`) — nenhum card é
// apagado nem movido silenciosamente. `referenceMonth` é normalizado para o
// primeiro dia do mês (UTC) para servir de chave natural de "qual ciclo é
// esse", sem impor fuso de exibição (isso é responsabilidade de `settings`).
enum CrmCycleStatus {
  OPEN
  CLOSED
}

model CrmCycle {
  id             String         @id @default(uuid())
  referenceMonth DateTime       @db.Date
  status         CrmCycleStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  closedById String?
  closedBy   User?   @relation("CrmCycleClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  opportunities        Opportunity[] @relation("OpportunityCycle")
  carriedOpportunities Opportunity[] @relation("OpportunityCarriedFromCycle")

  @@unique([referenceMonth])
  @@map("crm_cycles")
}

enum OpportunityStage {
  PROPOSTA
  NEGOCIACAO
  DESENVOLVIMENTO
  QUALIDADE
  ENTREGA
  CONCLUIDO
}

enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
}

// Situação financeira simplificada — o financeiro de verdade (accounts_receivable,
// parcelas, baixa manual) é Sprint 9. Por ora só um rótulo informativo no card.
enum OpportunityFinancialStatus {
  PENDING
  PARTIAL
  PAID
}

model Opportunity {
  id    String @id @default(uuid())
  // Nome do projeto/oportunidade (ex.: "Suporte de câmera - Cliente X").
  title String

  // Valor negociado. Decimal desde já (nunca float em nenhuma camada, mesmo
  // antes da calculadora/orçamento existirem — regra do CLAUDE.md) — só é
  // preenchido de verdade a partir do Sprint 4/5 (calculadora e orçamento);
  // até lá é um valor informado manualmente pelo usuário no card.
  value Decimal @default(0) @db.Decimal(12, 2)

  stage           OpportunityStage           @default(PROPOSTA)
  priority        OpportunityPriority        @default(MEDIUM)
  financialStatus OpportunityFinancialStatus @default(PENDING)

  deadlineAt DateTime?
  tags       String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Ciclo mensal ao qual a oportunidade está vinculada hoje (Sprint 5 —
  // CRM-5). Nulável porque oportunidades criadas antes desta migration não
  // têm ciclo retroativo (a migration é aditiva, não faz backfill) — toda
  // oportunidade criada a partir de agora recebe o ciclo aberto atual
  // automaticamente (src/modules/crm/services/opportunities.ts,
  // createOpportunity, via src/modules/crm/services/cycles.ts).
  cycleId String?
  cycle   CrmCycle? @relation("OpportunityCycle", fields: [cycleId], references: [id], onDelete: SetNull)

  // Preenchido só quando o fechamento de um ciclo decide "manter como
  // pendência carregada" para este card (em vez de "transportar" sem
  // marcação) — aponta para o ciclo (agora fechado) de onde ele veio. Resolve
  // o card "carregado" entre ciclos sem duplicar a linha (planejamento/01
  // §05, risco "Modelagem de ciclo mensal"; §11, diagrama relacional).
  carriedFromCycleId String?
  carriedFromCycle   CrmCycle? @relation("OpportunityCarriedFromCycle", fields: [carriedFromCycleId], references: [id], onDelete: SetNull)

  stageHistory OpportunityStageHistory[]
  quotes       Quote[]

  @@index([customerId])
  @@index([ownerId])
  @@index([stage])
  @@index([deadlineAt])
  @@index([cycleId])
  @@index([carriedFromCycleId])
  @@map("opportunities")
}

// Trilha de movimentação de etapa do Kanban — base do "dias na etapa" exibido
// no card (CRM-3) e da auditoria de quem moveu o quê. `fromStage` nulo marca a
// entrada inicial da oportunidade (criada direto em PROPOSTA). `note` é
// opcional na maioria das transições e obrigatória em algumas (ex.: reprovação
// de qualidade → volta para Desenvolvimento) — a obrigatoriedade é decidida em
// src/modules/crm/services/opportunities.ts, não no schema.
model OpportunityStageHistory {
  id        String            @id @default(uuid())
  fromStage OpportunityStage?
  toStage   OpportunityStage
  note      String?
  movedAt   DateTime          @default(now())

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("OpportunityStageMover", fields: [userId], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([userId])
  @@index([movedAt])
  @@map("opportunity_stage_history")
}

// ---------------------------------------------------------------------------
// Filamentos & Calculadora de precificação (Etapa 5, Sprint 4 — épico E4,
// histórias CALC-1..CALC-3). Fórmula completa e arredondamento:
// src/modules/jobs/services/pricing.ts. Modelo de dados: seção 11 da Etapa 1
// (tabelas `filaments`, `filament_movements`, `projects`, `jobs`,
// `job_filaments`).
//
// Sequenciamento deliberado (planejamento/05-backlog-sprints-dod.html §01):
// reserva/consumo real de filamento por uma ordem de produção (histórias
// PROD-1/PROD-3, decisão "Política de estoque" da Etapa 1 §03) só existe a
// partir do Sprint 6 — por isso `FilamentMovementType` NÃO tem "RESERVA"/
// "LIBERACAO" ainda, e `Job` não debita `Filament.availableGrams`. Ver TODO
// em src/modules/jobs/services/jobs.ts. `quotes`/orçamento (CALC-4/CALC-5) e
// o vínculo Job → Orçamento → Opportunity são Sprint 5 — não há FK daqui para
// `opportunities` ainda.
// ---------------------------------------------------------------------------

enum FilamentStatus {
  ACTIVE
  INACTIVE
}

// Tipos de movimentação de estoque cobertos neste sprint. "RESERVA" e
// "LIBERACAO" (ligados a um job de produção real) entram no Sprint 6 — ver
// nota acima.
enum FilamentMovementType {
  ENTRADA
  AJUSTE
  PERDA
  DEVOLUCAO
  CORRECAO
}

// Estoque de matéria-prima (filamento). `availableGrams` é o saldo corrente,
// sempre alterado através de `FilamentMovement` (nunca escrito diretamente
// fora de src/modules/filaments/services/filaments.ts) para preservar o
// histórico de saldo anterior/posterior e a regra de nunca ficar negativo.
// `version` é a coluna de lock otimista prevista na Etapa 1 §11 para a
// concorrência de estoque — o mecanismo de retry/lock em si é exercido a
// partir do Sprint 6, quando reservas reais concorrentes passam a existir.
model Filament {
  id                 String         @id @default(uuid())
  name               String
  brand              String?
  material           String
  color              String?
  batch              String?
  supplier           String?
  pricePerKg         Decimal        @db.Decimal(12, 2)
  initialWeightGrams Decimal        @db.Decimal(10, 2)
  availableGrams     Decimal        @db.Decimal(10, 2)
  minStockGrams      Decimal        @db.Decimal(10, 2)
  purchaseDate       DateTime?
  location           String?
  status             FilamentStatus @default(ACTIVE)
  notes              String?
  version            Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  movements    FilamentMovement[]
  jobFilaments JobFilament[]

  @@index([status])
  @@index([material])
  @@map("filaments")
}

// Trilha de movimentação de estoque — nunca editada/apagada. `quantityGrams`
// é o delta assinado efetivamente aplicado (positivo aumenta o saldo,
// negativo reduz); `balanceBefore`/`balanceAfter` são gravados a partir do
// saldo real pós-escrita dentro da mesma transação (nunca de uma leitura
// anterior, que poderia estar desatualizada sob concorrência — ver
// src/modules/filaments/services/filaments.ts).
model FilamentMovement {
  id            String               @id @default(uuid())
  type          FilamentMovementType
  quantityGrams Decimal              @db.Decimal(10, 2)
  balanceBefore Decimal              @db.Decimal(10, 2)
  balanceAfter  Decimal              @db.Decimal(10, 2)
  reason        String?
  createdAt     DateTime             @default(now())

  filamentId String
  filament   Filament @relation(fields: [filamentId], references: [id], onDelete: Restrict)

  userId String?
  user   User?   @relation("FilamentMovementActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([filamentId])
  @@index([userId])
  @@index([createdAt])
  @@map("filament_movements")
}

enum ProjectStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// Projeto standalone da calculadora (Sprint 4). Vínculo com Opportunity/CRM
// não existe ainda — ver cabeçalho da seção acima.
model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  category    String?
  status      ProjectStatus @default(PLANEJAMENTO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  responsibleId String?
  responsible   User?   @relation("ProjectResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  jobs Job[]

  @@index([customerId])
  @@index([responsibleId])
  @@index([status])
  @@map("projects")
}

// Job de cálculo da calculadora de precificação (CALC-2/CALC-3). Guarda as
// entradas usadas E o resultado calculado de forma imutável após criado —
// nunca recalculado/sobrescrito ao ler; uma nova simulação é sempre um novo
// Job. `ruleVersion` existe para permitir evoluir a fórmula no futuro sem
// invalidar jobs antigos (jobs antigos continuam mostrando o resultado que
// tinham quando calculados, mesmo que a fórmula de `ruleVersion` mais nova
// mude). Fórmula completa: src/modules/jobs/services/pricing.ts.
//
// `discount`/`freight`/`taxes`/`additionalCosts` são campos reservados para
// o orçamento (Sprint 5) — armazenados aqui desde já para não precisar
// migrar o schema depois, mas NÃO entram no cálculo de `finalPrice` neste
// sprint (a fórmula da Etapa 1 §10 não os inclui ainda).
model Job {
  id String @id @default(uuid())

  // --- entradas (imutáveis após criado) ---
  powerWatts     Decimal @db.Decimal(10, 2)
  printHours     Decimal @db.Decimal(10, 2)
  kwhPrice       Decimal @db.Decimal(12, 2)
  // Percentuais armazenados como fração 0-1 (0.2000 = 20%) — nunca 0-100.
  maintenancePct Decimal @db.Decimal(5, 4)
  safetyPct      Decimal @db.Decimal(5, 4)
  profitPct      Decimal @db.Decimal(5, 4)

  quantityProduced Int      @default(1)
  discount         Decimal? @db.Decimal(12, 2)
  freight          Decimal? @db.Decimal(12, 2)
  taxes            Decimal? @db.Decimal(12, 2)
  additionalCosts  Decimal? @db.Decimal(12, 2)

  // --- resultado calculado (imutável após criado) ---
  ruleVersion      String  @default("v1")
  filamentsCost    Decimal @db.Decimal(12, 2)
  energyCost       Decimal @db.Decimal(12, 2)
  directCost       Decimal @db.Decimal(12, 2)
  finalPrice       Decimal @db.Decimal(12, 2)
  maintenanceValue Decimal @db.Decimal(12, 2)
  safetyValue      Decimal @db.Decimal(12, 2)
  profitValue      Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  jobFilaments  JobFilament[]
  // Versões de orçamento geradas a partir deste job (Sprint 5 — CALC-4). Um
  // mesmo Job pode originar mais de uma QuoteVersion (ex.: reenviado com
  // desconto diferente em uma nova versão) — o Job em si continua imutável.
  quoteVersions QuoteVersion[]

  @@index([projectId])
  @@map("jobs")
}

// Associativa job x filamento. Snapshot imobilizado do preço/kg no momento
// do cálculo (`pricePerKgAtTime`) para que o job continue exibindo o custo
// correto mesmo que o preço do filamento mude depois — a fonte de verdade do
// resultado é sempre o que foi persistido aqui, nunca um recálculo posterior
// contra `Filament.pricePerKg` atual.
//
// TODO (Sprint 6 — módulo de produção): hoje `gramsUsed` é só a estimativa da
// calculadora, sem nenhum reflexo em `Filament.availableGrams`. Quando a
// produção real existir, este mesmo registro (ou uma tabela irmã) passa a
// também guardar `gramsActual` e a acionar `FilamentMovement` do tipo reserva
///consumo — não redesenhar este schema para isso, só estender.
model JobFilament {
  id               String  @id @default(uuid())
  gramsUsed        Decimal @db.Decimal(10, 2)
  pricePerKgAtTime Decimal @db.Decimal(12, 2)
  costCalculated   Decimal @db.Decimal(12, 2)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  filamentId String
  filament   Filament @relation(fields: [filamentId], references: [id], onDelete: Restrict)

  @@index([jobId])
  @@index([filamentId])
  @@map("job_filaments")
}

// ---------------------------------------------------------------------------
// Orçamento (Etapa 5, Sprint 5 — épico E4, histórias CALC-4/CALC-5). Conecta
// o que a calculadora já produz (`Job`) a uma `Opportunity` do Kanban CRM.
//
// Versionamento (planejamento/01-visao-arquitetura.html §11, "Versionamento":
// "orçamento vira nova linha em quote_versions a cada revisão" — e o critério
// de aceite crítico explícito de planejamento/02-personas-jornadas-historias
// .html §05, "Alterar orçamento já aprovado"): NENHUMA função deste módulo
// atualiza os campos monetários de uma `QuoteVersion` já criada — "editar" um
// orçamento é sempre criar uma nova `QuoteVersion` (número de versão
// incrementado), nunca um UPDATE sobre a existente. A versão aprovada
// original permanece intacta e consultável no histórico
// (src/modules/quotes/services/quotes.ts).
//
// `Quote` é o cabeçalho que agrupa as versões de uma negociação; `status`
// nele é só um espelho conveniente do status da versão mais recente (para
// filtrar/listar sem juntar com `quote_versions`) — a fonte de verdade de
// "está aprovado?" é sempre a existência de uma `QuoteVersion` com
// `status = APPROVED` (é isso que src/modules/crm/services/opportunities.ts,
// `validateTransition`, passa a checar de verdade na transição
// Negociação → Desenvolvimento).
// ---------------------------------------------------------------------------

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

model Quote {
  id     String      @id @default(uuid())
  status QuoteStatus @default(DRAFT)

  // Validade da proposta vigente (data limite para o cliente decidir).
  validUntil DateTime?
  // Motivo de perda — preenchido quando `status` vira REJECTED (rejeição da
  // versão vigente pelo cliente). Nunca apagado ao criar uma nova versão
  // depois: uma nova versão simplesmente move `status` para DRAFT de novo.
  lostReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Restrict)

  versions QuoteVersion[]

  @@index([opportunityId])
  @@map("quotes")
}

// Uma linha imutável por revisão do orçamento — nunca sobrescrita (ver
// cabeçalho da seção). `versionNumber` é sequencial por `quoteId`, começando
// em 1. Vem da calculadora (`jobId` preenchido, `isManual = false`, valores
// copiados do `Job` já calculado — CALC-2/CALC-3) OU é manual
// (`jobId = null`, `isManual = true`, exige `manualJustification` — regra do
// briefing original "orçamento manual com justificativa").
model QuoteVersion {
  id            String      @id @default(uuid())
  versionNumber Int
  status        QuoteStatus @default(DRAFT)

  isManual            Boolean @default(false)
  manualJustification String?

  // valor original (antes do desconto), desconto e valor final — todos
  // Decimal, nunca float, em qualquer camada (regra do CLAUDE.md).
  originalValue Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  finalValue    Decimal @db.Decimal(12, 2)

  paymentTerms     String?
  deliveryDeadline DateTime?
  quantity         Int       @default(1)
  notes            String?

  sentAt     DateTime?
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // Preenchido só quando esta versão veio da calculadora (reaproveita o
  // preço já calculado do Job — CALC-4). Null quando é um orçamento manual.
  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([quoteId, versionNumber])
  @@index([quoteId])
  @@index([jobId])
  @@index([status])
