// ERS 3D — Gestão de Soluções e Fabricações
// Sprint 0/1 scope: fundação (usuários, permissões por ação, auditoria).
// Demais módulos (customers, crm, quotes, jobs, filaments, inventory, quality,
// deliveries, finance, ...) entram em schemas incrementais nos próximos sprints,
// conforme o roadmap da Etapa 5.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles                   UserRole[]
  auditLogs                   AuditLog[]
  // Clientes onde este usuário é o responsável comercial (Sprint 2 — customers.ownerId).
  customers                   Customer[]
  // Oportunidades onde este usuário é o responsável comercial (Sprint 3 — opportunities.ownerId).
  ownedOpportunities          Opportunity[]             @relation("OpportunityOwner")
  // Movimentações de etapa do Kanban feitas por este usuário (Sprint 3).
  opportunityStageMoves       OpportunityStageHistory[] @relation("OpportunityStageMover")
  // Movimentações de estoque de filamento feitas por este usuário (Sprint 4).
  filamentMovements           FilamentMovement[]        @relation("FilamentMovementActor")
  // Projetos onde este usuário é o responsável técnico (Sprint 4 — projects.responsibleId).
  responsibleProjects         Project[]                 @relation("ProjectResponsible")
  // Ciclos mensais fechados por este usuário (Sprint 5 — crm_cycles.closed_by).
  closedCycles                CrmCycle[]                @relation("CrmCycleClosedBy")
  // Ordens de produção onde este usuário é o responsável técnico (Sprint 6 —
  // production_orders.responsible_id).
  responsibleProductionOrders ProductionOrder[]         @relation("ProductionOrderResponsible")
  // Checklists de qualidade registrados por este usuário (Sprint 7 —
  // quality_checks.checked_by_id).
  qualityChecksPerformed      QualityCheck[]            @relation("QualityCheckChecker")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  // Ação nomeada, ex.: "finance.read", "inventory.adjust", "crm.stage.revert"
  // A checagem de acesso é sempre feita contra este slug, nunca contra o nome do perfil.
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Trilha de auditoria transversal (Etapa 1, seção 11 / Etapa 3, seção 04).
// Escrita sempre via src/lib/audit.ts — nunca manualmente em cada service.
model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  reason     String?
  userId     String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Clientes (Etapa 5, Sprint 2 — épico E2, histórias CUST-1..CUST-4).
// ---------------------------------------------------------------------------

enum CustomerType {
  PF
  PJ
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

// "Empresa" do cliente é uma tag leve para agrupar/filtrar em relatórios e
// dashboard (decisão registrada em planejamento/01-visao-arquitetura.html,
// callout "Decidido · Campo 'empresa' do cliente"): não tem contatos,
// endereços nem oportunidades próprios — só nome e segmento opcional.
model Company {
  id        String   @id @default(uuid())
  name      String
  segment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers Customer[]

  @@map("companies")
}

// Cadastro de clientes PF/PJ (CUST-1). Documento (CPF/CNPJ) e telefones são
// normalizados (somente dígitos) por src/modules/customers/services/customers.ts
// antes de gravar, para viabilizar a checagem de duplicidade (CUST-2). Não há
// unique constraint de banco sobre email/documento/telefone de propósito: a
// jornada "Detecção de duplicidade de cliente" (Etapa 2, seção 03) exige que o
// alerta seja apresentado ao usuário, que decide confirmar o cadastro mesmo
// assim — nunca um bloqueio silencioso no banco.
model Customer {
  id            String         @id @default(uuid())
  name          String
  type          CustomerType
  document      String?
  email         String?
  phone         String?
  whatsapp      String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  origin        String?
  segment       String?
  notes         String?
  tags          String[]       @default([])
  status        CustomerStatus @default(ACTIVE)
  lastContactAt DateTime?
  nextContactAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  opportunities Opportunity[]
  // Projetos da calculadora vinculados a este cliente (Sprint 4, opcional).
  projects      Project[]

  @@index([email])
  @@index([document])
  @@index([phone])
  @@index([whatsapp])
  @@index([ownerId])
  @@index([companyId])
  @@map("customers")
}

// ---------------------------------------------------------------------------
// Kanban CRM (Etapa 5, Sprint 3 — épico E3, histórias CRM-1..CRM-5) + Ciclo
// mensal e Orçamento (Sprint 5 — épico E4 CALC-4/CALC-5, épico E3 CRM-5).
// Fluxo e pré-condições de transição: planejamento/01-visao-arquitetura.html
// seções 08/09. Quem pode mover cada transição por perfil:
// planejamento/02-personas-jornadas-historias.html seção 06.
//
// A partir do Sprint 5, `quotes`/`quote_versions` (orçamento formal,
// versionado — nunca sobrescrito, ver `QuoteVersion` abaixo) e `crm_cycles`
// (ciclo mensal, `Opportunity.cycleId`/`carriedFromCycleId`) existem de
// verdade — a pré-condição "orçamento aprovado" de Negociação → Desenvolvimento
// passou a ser checada de verdade em `validateTransition`
// (src/modules/crm/services/opportunities.ts). As demais pré-condições que
// ainda dependem de módulos futuros (produção concluída, qualidade aprovada,
// entrega registrada) continuam marcadas como TODO — nunca uma checagem
// falsa, nunca um bloqueio inventado.
// ---------------------------------------------------------------------------

// Ciclo mensal do Kanban (CRM-5). Fechamento nunca é destrutivo: cards ainda
// abertos (stage != CONCLUIDO) no ciclo sendo fechado exigem uma decisão
// explícita por card (ver `Opportunity.carriedFromCycleId` e
// src/modules/crm/services/cycles.ts, função `closeCycle`) — nenhum card é
// apagado nem movido silenciosamente. `referenceMonth` é normalizado para o
// primeiro dia do mês (UTC) para servir de chave natural de "qual ciclo é
// esse", sem impor fuso de exibição (isso é responsabilidade de `settings`).
enum CrmCycleStatus {
  OPEN
  CLOSED
}

model CrmCycle {
  id             String         @id @default(uuid())
  referenceMonth DateTime       @db.Date
  status         CrmCycleStatus @default(OPEN)
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  closedById String?
  closedBy   User?   @relation("CrmCycleClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  opportunities        Opportunity[] @relation("OpportunityCycle")
  carriedOpportunities Opportunity[] @relation("OpportunityCarriedFromCycle")

  @@unique([referenceMonth])
  @@map("crm_cycles")
}

enum OpportunityStage {
  PROPOSTA
  NEGOCIACAO
  DESENVOLVIMENTO
  QUALIDADE
  ENTREGA
  CONCLUIDO
}

enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
}

// Situação financeira simplificada — o financeiro de verdade (accounts_receivable,
// parcelas, baixa manual) é Sprint 9. Por ora só um rótulo informativo no card.
enum OpportunityFinancialStatus {
  PENDING
  PARTIAL
  PAID
}

model Opportunity {
  id    String @id @default(uuid())
  // Nome do projeto/oportunidade (ex.: "Suporte de câmera - Cliente X").
  title String

  // Valor negociado. Decimal desde já (nunca float em nenhuma camada, mesmo
  // antes da calculadora/orçamento existirem — regra do CLAUDE.md) — só é
  // preenchido de verdade a partir do Sprint 4/5 (calculadora e orçamento);
  // até lá é um valor informado manualmente pelo usuário no card.
  value Decimal @default(0) @db.Decimal(12, 2)

  stage           OpportunityStage           @default(PROPOSTA)
  priority        OpportunityPriority        @default(MEDIUM)
  financialStatus OpportunityFinancialStatus @default(PENDING)

  deadlineAt DateTime?
  tags       String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Ciclo mensal ao qual a oportunidade está vinculada hoje (Sprint 5 —
  // CRM-5). Nulável porque oportunidades criadas antes desta migration não
  // têm ciclo retroativo (a migration é aditiva, não faz backfill) — toda
  // oportunidade criada a partir de agora recebe o ciclo aberto atual
  // automaticamente (src/modules/crm/services/opportunities.ts,
  // createOpportunity, via src/modules/crm/services/cycles.ts).
  cycleId String?
  cycle   CrmCycle? @relation("OpportunityCycle", fields: [cycleId], references: [id], onDelete: SetNull)

  // Preenchido só quando o fechamento de um ciclo decide "manter como
  // pendência carregada" para este card (em vez de "transportar" sem
  // marcação) — aponta para o ciclo (agora fechado) de onde ele veio. Resolve
  // o card "carregado" entre ciclos sem duplicar a linha (planejamento/01
  // §05, risco "Modelagem de ciclo mensal"; §11, diagrama relacional).
  carriedFromCycleId String?
  carriedFromCycle   CrmCycle? @relation("OpportunityCarriedFromCycle", fields: [carriedFromCycleId], references: [id], onDelete: SetNull)

  stageHistory     OpportunityStageHistory[]
  quotes           Quote[]
  // Ordens de produção geradas para esta oportunidade (Sprint 6) — normalmente
  // uma só (criada automaticamente na aprovação de uma versão vinda de Job, ou
  // manualmente para uma versão manual sem job), mas o schema não impõe
  // unicidade para não travar um retrabalho futuro (Sprint 7) que precise de
  // mais de uma ordem ao longo do tempo.
  productionOrders ProductionOrder[]
  // Checklists de qualidade (Sprint 7) rodados para esta oportunidade —
  // normalmente um por ciclo de produção (original + um por retrabalho), o
  // histórico completo (inclusive reprovações antigas) fica sempre
  // consultável (QUAL-3), nunca apagado.
  qualityChecks    QualityCheck[]

  @@index([customerId])
  @@index([ownerId])
  @@index([stage])
  @@index([deadlineAt])
  @@index([cycleId])
  @@index([carriedFromCycleId])
  @@map("opportunities")
}

// Trilha de movimentação de etapa do Kanban — base do "dias na etapa" exibido
// no card (CRM-3) e da auditoria de quem moveu o quê. `fromStage` nulo marca a
// entrada inicial da oportunidade (criada direto em PROPOSTA). `note` é
// opcional na maioria das transições e obrigatória em algumas (ex.: reprovação
// de qualidade → volta para Desenvolvimento) — a obrigatoriedade é decidida em
// src/modules/crm/services/opportunities.ts, não no schema.
model OpportunityStageHistory {
  id        String            @id @default(uuid())
  fromStage OpportunityStage?
  toStage   OpportunityStage
  note      String?
  movedAt   DateTime          @default(now())

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("OpportunityStageMover", fields: [userId], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([userId])
  @@index([movedAt])
  @@map("opportunity_stage_history")
}

// ---------------------------------------------------------------------------
// Filamentos & Calculadora de precificação (Etapa 5, Sprint 4 — épico E4,
// histórias CALC-1..CALC-3). Fórmula completa e arredondamento:
// src/modules/jobs/services/pricing.ts. Modelo de dados: seção 11 da Etapa 1
// (tabelas `filaments`, `filament_movements`, `projects`, `jobs`,
// `job_filaments`).
//
// Sequenciamento deliberado (planejamento/05-backlog-sprints-dod.html §01):
// reserva/consumo real de filamento por uma ordem de produção (histórias
// PROD-1/PROD-3, decisão "Política de estoque" da Etapa 1 §03) passou a
// existir a partir do Sprint 6 — `FilamentMovementType` ganhou "RESERVA"/
// "LIBERACAO_RESERVA" (ver `ProductionOrder` mais abaixo e
// src/modules/quotes/services/quotes.ts, `approveVersion`, e
// src/modules/production/services/production.ts, `completeProduction`).
// `Job` continua imutável e não debita `Filament.availableGrams` diretamente
// — quem debita é a aprovação da versão de orçamento (reserva) e a conclusão
// da produção (ajuste reserva→consumo real via `JobFilament.gramsActual`).
// ---------------------------------------------------------------------------

enum FilamentStatus {
  ACTIVE
  INACTIVE
}

// Tipos de movimentação de estoque. "RESERVA" debita o saldo disponível no
// momento da aprovação do orçamento (Negociação → Desenvolvimento, decisão
// "Política de estoque" já confirmada na Etapa 1 §03) e também cobre consumo
// adicional na conclusão da produção quando as gramas reais excedem o
// estimado; "LIBERACAO_RESERVA" credita de volta quando as gramas reais são
// menores que o reservado, ou quando uma reserva precisa ser desfeita. Ambas
// passam pela mesma escrita condicional atômica de `recordMovementInTx`
// (src/modules/filaments/services/filaments.ts) — nunca um caminho próprio.
enum FilamentMovementType {
  ENTRADA
  AJUSTE
  PERDA
  DEVOLUCAO
  CORRECAO
  RESERVA
  LIBERACAO_RESERVA
}

// Estoque de matéria-prima (filamento). `availableGrams` é o saldo corrente,
// sempre alterado através de `FilamentMovement` (nunca escrito diretamente
// fora de src/modules/filaments/services/filaments.ts) para preservar o
// histórico de saldo anterior/posterior e a regra de nunca ficar negativo.
// `version` é a coluna de lock otimista prevista na Etapa 1 §11 para a
// concorrência de estoque — o mecanismo de retry/lock em si é exercido a
// partir do Sprint 6, quando reservas reais concorrentes passam a existir.
model Filament {
  id                 String         @id @default(uuid())
  name               String
  brand              String?
  material           String
  color              String?
  batch              String?
  supplier           String?
  pricePerKg         Decimal        @db.Decimal(12, 2)
  initialWeightGrams Decimal        @db.Decimal(10, 2)
  availableGrams     Decimal        @db.Decimal(10, 2)
  minStockGrams      Decimal        @db.Decimal(10, 2)
  purchaseDate       DateTime?
  location           String?
  status             FilamentStatus @default(ACTIVE)
  notes              String?
  version            Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  movements    FilamentMovement[]
  jobFilaments JobFilament[]

  @@index([status])
  @@index([material])
  @@map("filaments")
}

// Trilha de movimentação de estoque — nunca editada/apagada. `quantityGrams`
// é o delta assinado efetivamente aplicado (positivo aumenta o saldo,
// negativo reduz); `balanceBefore`/`balanceAfter` são gravados a partir do
// saldo real pós-escrita dentro da mesma transação (nunca de uma leitura
// anterior, que poderia estar desatualizada sob concorrência — ver
// src/modules/filaments/services/filaments.ts).
model FilamentMovement {
  id            String               @id @default(uuid())
  type          FilamentMovementType
  quantityGrams Decimal              @db.Decimal(10, 2)
  balanceBefore Decimal              @db.Decimal(10, 2)
  balanceAfter  Decimal              @db.Decimal(10, 2)
  reason        String?
  createdAt     DateTime             @default(now())

  filamentId String
  filament   Filament @relation(fields: [filamentId], references: [id], onDelete: Restrict)

  userId String?
  user   User?   @relation("FilamentMovementActor", fields: [userId], references: [id], onDelete: SetNull)

  // Preenchido só para RESERVA/LIBERACAO_RESERVA geradas por uma ordem de
  // produção (Sprint 6) — rastreabilidade de "que ordem reservou/liberou
  // isto", sem que a origem seja obrigatória para os demais tipos de
  // movimentação manual (Sprint 4).
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id], onDelete: SetNull)

  @@index([filamentId])
  @@index([userId])
  @@index([createdAt])
  @@index([productionOrderId])
  @@map("filament_movements")
}

enum ProjectStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

// Projeto standalone da calculadora (Sprint 4). Vínculo com Opportunity/CRM
// não existe ainda — ver cabeçalho da seção acima.
model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  category    String?
  status      ProjectStatus @default(PLANEJAMENTO)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  responsibleId String?
  responsible   User?   @relation("ProjectResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  jobs Job[]

  @@index([customerId])
  @@index([responsibleId])
  @@index([status])
  @@map("projects")
}

// Job de cálculo da calculadora de precificação (CALC-2/CALC-3). Guarda as
// entradas usadas E o resultado calculado de forma imutável após criado —
// nunca recalculado/sobrescrito ao ler; uma nova simulação é sempre um novo
// Job. `ruleVersion` existe para permitir evoluir a fórmula no futuro sem
// invalidar jobs antigos (jobs antigos continuam mostrando o resultado que
// tinham quando calculados, mesmo que a fórmula de `ruleVersion` mais nova
// mude). Fórmula completa: src/modules/jobs/services/pricing.ts.
//
// `discount`/`freight`/`taxes`/`additionalCosts` são campos reservados para
// o orçamento (Sprint 5) — armazenados aqui desde já para não precisar
// migrar o schema depois, mas NÃO entram no cálculo de `finalPrice` neste
// sprint (a fórmula da Etapa 1 §10 não os inclui ainda).
model Job {
  id String @id @default(uuid())

  // --- entradas (imutáveis após criado) ---
  powerWatts     Decimal @db.Decimal(10, 2)
  printHours     Decimal @db.Decimal(10, 2)
  kwhPrice       Decimal @db.Decimal(12, 2)
  // Percentuais armazenados como fração 0-1 (0.2000 = 20%) — nunca 0-100.
  maintenancePct Decimal @db.Decimal(5, 4)
  safetyPct      Decimal @db.Decimal(5, 4)
  profitPct      Decimal @db.Decimal(5, 4)

  quantityProduced Int      @default(1)
  discount         Decimal? @db.Decimal(12, 2)
  freight          Decimal? @db.Decimal(12, 2)
  taxes            Decimal? @db.Decimal(12, 2)
  additionalCosts  Decimal? @db.Decimal(12, 2)

  // --- resultado calculado (imutável após criado) ---
  ruleVersion      String  @default("v1")
  filamentsCost    Decimal @db.Decimal(12, 2)
  energyCost       Decimal @db.Decimal(12, 2)
  directCost       Decimal @db.Decimal(12, 2)
  finalPrice       Decimal @db.Decimal(12, 2)
  maintenanceValue Decimal @db.Decimal(12, 2)
  safetyValue      Decimal @db.Decimal(12, 2)
  profitValue      Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  jobFilaments     JobFilament[]
  // Versões de orçamento geradas a partir deste job (Sprint 5 — CALC-4). Um
  // mesmo Job pode originar mais de uma QuoteVersion (ex.: reenviado com
  // desconto diferente em uma nova versão) — o Job em si continua imutável.
  quoteVersions    QuoteVersion[]
  // Ordens de produção geradas a partir deste job (Sprint 6 — normalmente uma
  // só, criada automaticamente quando a QuoteVersion correspondente é
  // aprovada).
  productionOrders ProductionOrder[]

  @@index([projectId])
  @@map("jobs")
}

// Associativa job x filamento. Snapshot imobilizado do preço/kg no momento
// do cálculo (`pricePerKgAtTime`) para que o job continue exibindo o custo
// correto mesmo que o preço do filamento mude depois — a fonte de verdade do
// resultado é sempre o que foi persistido aqui, nunca um recálculo posterior
// contra `Filament.pricePerKg` atual.
//
// `gramsUsed` é a estimativa da calculadora — reservada (debitada do saldo
// disponível) quando a versão de orçamento originada deste job é aprovada
// (src/modules/quotes/services/quotes.ts, `approveVersion`). `gramsActual`
// (Sprint 6) é preenchido só na conclusão da produção
// (src/modules/production/services/production.ts, `completeProduction`),
// com a diferença para `gramsUsed` liberada (LIBERACAO_RESERVA) ou consumida
// a mais (RESERVA) — nunca redesenhado, só estendido conforme o TODO
// original previa.
model JobFilament {
  id               String   @id @default(uuid())
  gramsUsed        Decimal  @db.Decimal(10, 2)
  gramsActual      Decimal? @db.Decimal(10, 2)
  pricePerKgAtTime Decimal  @db.Decimal(12, 2)
  costCalculated   Decimal  @db.Decimal(12, 2)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  filamentId String
  filament   Filament @relation(fields: [filamentId], references: [id], onDelete: Restrict)

  @@index([jobId])
  @@index([filamentId])
  @@map("job_filaments")
}

// ---------------------------------------------------------------------------
// Orçamento (Etapa 5, Sprint 5 — épico E4, histórias CALC-4/CALC-5). Conecta
// o que a calculadora já produz (`Job`) a uma `Opportunity` do Kanban CRM.
//
// Versionamento (planejamento/01-visao-arquitetura.html §11, "Versionamento":
// "orçamento vira nova linha em quote_versions a cada revisão" — e o critério
// de aceite crítico explícito de planejamento/02-personas-jornadas-historias
// .html §05, "Alterar orçamento já aprovado"): NENHUMA função deste módulo
// atualiza os campos monetários de uma `QuoteVersion` já criada — "editar" um
// orçamento é sempre criar uma nova `QuoteVersion` (número de versão
// incrementado), nunca um UPDATE sobre a existente. A versão aprovada
// original permanece intacta e consultável no histórico
// (src/modules/quotes/services/quotes.ts).
//
// `Quote` é o cabeçalho que agrupa as versões de uma negociação; `status`
// nele é só um espelho conveniente do status da versão mais recente (para
// filtrar/listar sem juntar com `quote_versions`) — a fonte de verdade de
// "está aprovado?" é sempre a existência de uma `QuoteVersion` com
// `status = APPROVED` (é isso que src/modules/crm/services/opportunities.ts,
// `validateTransition`, passa a checar de verdade na transição
// Negociação → Desenvolvimento).
// ---------------------------------------------------------------------------

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

model Quote {
  id     String      @id @default(uuid())
  status QuoteStatus @default(DRAFT)

  // Validade da proposta vigente (data limite para o cliente decidir).
  validUntil DateTime?
  // Motivo de perda — preenchido quando `status` vira REJECTED (rejeição da
  // versão vigente pelo cliente). Nunca apagado ao criar uma nova versão
  // depois: uma nova versão simplesmente move `status` para DRAFT de novo.
  lostReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Restrict)

  versions QuoteVersion[]

  @@index([opportunityId])
  @@map("quotes")
}

// Uma linha imutável por revisão do orçamento — nunca sobrescrita (ver
// cabeçalho da seção). `versionNumber` é sequencial por `quoteId`, começando
// em 1. Vem da calculadora (`jobId` preenchido, `isManual = false`, valores
// copiados do `Job` já calculado — CALC-2/CALC-3) OU é manual
// (`jobId = null`, `isManual = true`, exige `manualJustification` — regra do
// briefing original "orçamento manual com justificativa").
model QuoteVersion {
  id            String      @id @default(uuid())
  versionNumber Int
  status        QuoteStatus @default(DRAFT)

  isManual            Boolean @default(false)
  manualJustification String?

  // valor original (antes do desconto), desconto e valor final — todos
  // Decimal, nunca float, em qualquer camada (regra do CLAUDE.md).
  originalValue Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  finalValue    Decimal @db.Decimal(12, 2)

  paymentTerms     String?
  deliveryDeadline DateTime?
  quantity         Int       @default(1)
  notes            String?

  sentAt     DateTime?
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // Preenchido só quando esta versão veio da calculadora (reaproveita o
  // preço já calculado do Job — CALC-4). Null quando é um orçamento manual.
  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([quoteId, versionNumber])
  @@index([quoteId])
  @@index([jobId])
  @@index([status])
  @@map("quote_versions")
}

// ---------------------------------------------------------------------------
// Produção (Etapa 5, Sprint 6 — épico E5, histórias PROD-1..PROD-5). Conecta
// o orçamento aprovado (`QuoteVersion`, Sprint 5) e o job calculado (`Job`,
// Sprint 4) a uma ordem de produção real, com reserva/consumo de fato de
// filamento (`FilamentMovement` tipos RESERVA/LIBERACAO_RESERVA).
//
// Política de estoque (decisão já confirmada em
// planejamento/01-visao-arquitetura.html §03, refletida em §09/§11): o
// filamento é RESERVADO no momento em que uma QuoteVersion vinda de um Job é
// aprovada (Negociação → Desenvolvimento) — não apenas quando a impressão
// começa de fato. A conversão para consumo definitivo (gramas reais, que
// podem diferir da estimativa) acontece ao concluir a produção
// (`completeProduction`, src/modules/production/services/production.ts):
// diferença a mais é consumida (nova RESERVA, validando saldo adicional),
// diferença a menos é devolvida (LIBERACAO_RESERVA). Tudo em transação — se
// qualquer filamento não tiver saldo, nada é aplicado (caso crítico PROD-5 /
// "Editar job já com estoque reservado" da Etapa 2 §05).
//
// Impressoras (decisão já confirmada, Etapa 1 §03): só 3 registros esperados,
// sem agenda visual/calendário — `Printer` é uma tabela leve só para nomear a
// máquina usada.
//
// Vínculo com uma QuoteVersion MANUAL (sem Job): `approveVersion` não reserva
// nada nem cria ProductionOrder automaticamente nesse caso — TODO documentado
// em `approveVersion` (src/modules/quotes/services/quotes.ts): o usuário cria
// a ordem de produção manualmente (`createManualProductionOrder`), vinculada
// só à Opportunity, sem job/reserva automática (o estoque, se usado, é
// gerenciado manualmente via `/estoque`, mesma tela do Sprint 4).
// ---------------------------------------------------------------------------

enum PrinterStatus {
  ATIVA
  MANUTENCAO
  INATIVA
}

// Tabela leve (Etapa 1 §03, "Decidido · Impressoras") — só nome e status, sem
// agenda/calendário. ERS 3D opera 3 impressoras hoje; o seed cria essas 3.
model Printer {
  id        String        @id @default(uuid())
  name      String
  status    PrinterStatus @default(ATIVA)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  productionOrders ProductionOrder[]

  @@unique([name])
  @@map("printers")
}

// Status de impressão da ordem (PROD-2). O "status de prazo" (no prazo /
// próximo do vencimento / atrasado) NÃO é armazenado — é sempre calculado em
// runtime a partir de `plannedEndAt` vs. agora
// (src/modules/production/format.ts, `getProductionDeadlineCounter`), mesma
// filosofia do indicador de prazo do Kanban (src/modules/crm/format.ts).
enum ProductionPrintStatus {
  AGUARDANDO
  IMPRIMINDO
  CONCLUIDA
  FALHOU
}

model ProductionOrder {
  id String @id @default(uuid())

  printStatus ProductionPrintStatus @default(AGUARDANDO)

  plannedStartAt DateTime?
  plannedEndAt   DateTime?
  // Preenchido só na conclusão (`completeProduction`) — horas reais de
  // impressão apontadas pelo Operador (PROD-3).
  actualHours    Decimal?  @db.Decimal(10, 2)

  technicalNotes String?
  completedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Restrict)

  // Nulo quando a ordem foi criada manualmente a partir de uma QuoteVersion
  // sem Job (ver cabeçalho da seção) — nesse caso não há JobFilament para
  // reconciliar e `completeProduction` não faz reserva/consumo de filamento.
  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  printerId String?
  printer   Printer? @relation(fields: [printerId], references: [id], onDelete: SetNull)

  responsibleId String?
  responsible   User?   @relation("ProductionOrderResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  filamentMovements FilamentMovement[]
  // Checklists de qualidade rodados contra esta ordem específica (Sprint 7)
  // — uma ordem de retrabalho (aberta na reprovação) recebe seu próprio
  // checklist depois de concluída de novo.
  qualityChecks     QualityCheck[]

  @@index([opportunityId])
  @@index([jobId])
  @@index([printerId])
  @@index([responsibleId])
  @@index([printStatus])
  @@map("production_orders")
}

// ---------------------------------------------------------------------------
// Qualidade (Etapa 5, Sprint 7 — épico E6, histórias QUAL-1..QUAL-3). Roda um
// checklist (hoje uma lista fixa de itens — dimensões, integridade
// estrutural, cor, acabamento, resistência, encaixe, quantidade,
// personalização, limpeza, embalagem; ver
// src/modules/quality/format.ts, QUALITY_CHECKLIST_ITEMS — checklist
// configurável de verdade é um refinamento futuro, fora de escopo aqui)
// contra uma ProductionOrder já CONCLUIDA (Sprint 6).
//
// Reprovação (QUAL-2, caso crítico explícito "Qualidade reprovada gera
// retrabalho" — planejamento/02-personas-jornadas-historias.html §05): motivo
// obrigatório, devolve a Opportunity para DESENVOLVIMENTO e abre uma nova
// ProductionOrder (status AGUARDANDO, mesmo jobId da ordem original — permite
// consumo adicional de material quando o retrabalho for concluído,
// reaproveitando `completeProduction` já existente sem recriar a lógica de
// reconciliação de estoque) — tudo na MESMA transação
// (src/modules/quality/services/quality.ts, `submitQualityCheck`). Esse
// service não importa `src/modules/crm/services/opportunities.ts` nem
// `src/modules/production/services/production.ts` para fazer essa escrita:
// como `opportunities.ts` já depende deste módulo (pré-condição real de
// Qualidade → Entrega, ver `hasApprovedQualityCheck`), importar de volta
// fecharia um ciclo entre módulos de serviço — o mesmo problema já resolvido
// entre `quotes` e `production` (ver comentário em `approveVersion`,
// src/modules/quotes/services/quotes.ts): a escrita é feita diretamente, no
// mesmo formato que `moveStage`/a criação de ordem já produzem, dentro da
// transação.
//
// O QualityCheck reprovado e seus itens NUNCA são apagados nem alterados
// depois — ficam no histórico para sempre, mesmo que um retrabalho seguinte
// seja aprovado (QUAL-3, `getQualityHistoryForOpportunity`).
//
// `evidencePhotoUrl` é só um campo de texto/URL por enquanto — upload real de
// arquivo é módulo `files`, fora de escopo deste sprint.
// ---------------------------------------------------------------------------

enum QualityCheckResult {
  APROVADO
  REPROVADO
  APROVADO_COM_RESSALVA
}

model QualityCheck {
  id     String             @id @default(uuid())
  result QualityCheckResult

  // Obrigatório quando result = REPROVADO (validado em
  // src/modules/quality/services/quality.ts, nunca imposto pelo schema) —
  // null nos demais resultados.
  rejectionReason String?

  checkedAt DateTime @default(now())
  createdAt DateTime @default(now())

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Restrict)

  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Restrict)

  checkedById String?
  checkedBy   User?   @relation("QualityCheckChecker", fields: [checkedById], references: [id], onDelete: SetNull)

  items QualityCheckItem[]

  @@index([opportunityId])
  @@index([productionOrderId])
  @@index([checkedById])
  @@index([checkedAt])
  @@map("quality_checks")
}

// Um item do checklist por linha — hoje sempre os itens fixos de
// QUALITY_CHECKLIST_ITEMS, um QualityCheckItem por item marcado no momento do
// checklist. `notes`/`evidencePhotoUrl` são opcionais por item.
model QualityCheckItem {
  id               String  @id @default(uuid())
  label            String
  passed           Boolean
  notes            String?
  evidencePhotoUrl String?

  qualityCheckId String
  qualityCheck   QualityCheck @relation(fields: [qualityCheckId], references: [id], onDelete: Cascade)

  @@index([qualityCheckId])
  @@map("quality_check_items")
}
