# Postgres (Neon em produção/homologação, Postgres local ou Neon branch em dev)
DATABASE_URL="postgresql://user:password@localhost:5432/ers3d_dev"

# Auth.js — gerar com: npx auth secret
AUTH_SECRET="troque-por-um-valor-aleatorio-gerado-localmente"

# URL pública da aplicação (usada pelo Auth.js para callbacks)
AUTH_URL="http://localhost:3000"

# Seed inicial do usuário ROOT (Sprint 0) — trocar a senha no primeiro login
SEED_ROOT_EMAIL="admin@ers3d.com.br"
SEED_ROOT_PASSWORD="troque-esta-senha-no-primeiro-login"
